<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE ejb-jar PUBLIC 
    "-//Sun Microsystems, Inc.//DTD Enterprise JavaBeans 2.0//EN" 
    "http://java.sun.com/dtd/ejb-jar_2_0.dtd">

<ejb-jar>
    <display-name>Credit Card Application EJBs</display-name>
    
    <enterprise-beans>
        <!-- Credit Card Application Session Bean -->
        <session>
            <ejb-name>CreditCardApplicationBean</ejb-name>
            <home>com.firstbank.creditcard.ejb.session.CreditCardApplicationHome</home>
            <remote>com.firstbank.creditcard.ejb.session.CreditCardApplicationRemote</remote>
            <ejb-class>com.firstbank.creditcard.ejb.session.CreditCardApplicationBean</ejb-class>
            <session-type>Stateless</session-type>
            <transaction-type>Container</transaction-type>
        </session>
    </enterprise-beans>
    
    <assembly-descriptor>
        <container-transaction>
            <method>
                <ejb-name>CreditCardApplicationBean</ejb-name>
                <method-name>*</method-name>
            </method>
            <trans-attribute>Required</trans-attribute>
        </container-transaction>
    </assembly-descriptor>
</ejb-jar>

